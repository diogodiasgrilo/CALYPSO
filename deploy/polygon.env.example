# Polygon.io API key for HYDRA Brandon GEX features.
#
# Deploy steps (one-time):
#   1. Sign up at https://polygon.io and grab your API key from the dashboard.
#      The Options Starter plan ($29/mo) covers per-strike open interest +
#      implied volatility for SPX. Greeks are not included on Starter — the
#      bot computes gamma from IV via Black-Scholes as a fallback, which
#      matches Polygon's own gamma to within rounding.
#   2. SSH to the VM:  gcloud compute ssh calypso-bot --zone=us-east1-b
#   3. sudo install -d -m 0750 /etc/calypso
#   4. sudo cp deploy/polygon.env.example /etc/calypso/polygon.env
#   5. sudo nano /etc/calypso/polygon.env  →  paste your key
#   6. sudo chmod 0640 /etc/calypso/polygon.env  ;  sudo chown root:calypso /etc/calypso/polygon.env
#   7. sudo systemctl restart hydra_variant_b hydra_variant_c
#
# The hydra_variant_b.service and hydra_variant_c.service unit files load this
# via `EnvironmentFile=-/etc/calypso/polygon.env`. The leading dash makes the
# file optional — if it's missing, the bot still starts; GEX features are
# disabled with a logged warning and the variant runs with TP + narrow_spread
# only.

POLYGON_API_KEY=replace-me-with-your-polygon-api-key
